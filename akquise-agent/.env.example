# Environment Variables
# Copy this file to .env and fill in your values

# General Settings
DEBUG=false
HEADLESS=true
TARGET_LOCATION=Heilbronn

# Scraper Settings
SCRAPER_TIMEOUT=30000
SCRAPER_RATE_LIMIT=2.0

# Proxy Settings
PROXY_ENABLED=false
# PROXY_FILE=config/proxies.txt

# Database
DATABASE_PATH=data/contacts.db

# Google Drive Integration
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_CREDENTIALS_FILE=config/credentials.json

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/akquise.log

# Company Information (for email templates)
COMPANY_NAME=SE Handwerk
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_WEBSITE=

# SMTP Email Settings (Namecheap Private Email)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_USER=kontakt@sehandwerk.de
SMTP_PASSWORD=your-password-here
SMTP_FROM_NAME=SE Handwerk GbR
SMTP_FROM_EMAIL=kontakt@sehandwerk.de
SMTP_USE_TLS=true
SMTP_DAILY_LIMIT=100
SMTP_RATE_LIMIT_SECONDS=10.0

# Follow-Up Settings
FOLLOWUP_DAY_1=7
FOLLOWUP_DAY_2=14

# IMAP Settings (for saving drafts to email folder)
IMAP_HOST=mail.privateemail.com
IMAP_PORT=993
IMAP_USER=kontakt@sehandwerk.de
IMAP_PASSWORD=your-password-here
IMAP_USE_SSL=true
IMAP_DRAFTS_FOLDER=Drafts